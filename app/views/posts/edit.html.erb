<% content_for :title, "Editing post" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6 flex justify-between items-center">
    <%= link_to "← Back to posts", posts_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
    <%= link_to "View post →", @post, class: "text-blue-600 hover:text-blue-800 font-medium" %>
  </div>
  
  <h1 class="text-3xl font-bold text-gray-800 mb-6">Editing post</h1>
  
  <div class="bg-white rounded-lg shadow-md p-6">
    <%= render "form", post: @post %>
  </div>
</div>
