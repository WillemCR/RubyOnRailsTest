<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ruby On Rails Test" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ruby On Rails Test">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gray-50 min-h-screen flex flex-col">
    <header class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center gap-2">
            <span class="text-2xl">✍️</span>
            <%= link_to "My Blog", root_path, class: "text-xl font-bold text-gray-900 hover:text-indigo-600 transition" %>
          </div>
          <nav class="flex items-center gap-4">
            <%= link_to "Posts", posts_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600 transition" %>
            <%= link_to "New Post", new_post_path, class: "inline-flex items-center gap-1.5 text-sm font-medium bg-indigo-600 hover:bg-indigo-700 text-white py-2 px-4 rounded-lg transition shadow-sm" %>
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-10">
      <% if notice.present? %>
        <div class="mb-6 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg px-4 py-3 text-sm font-medium">
          <span>✓</span>
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-6 flex items-center gap-2 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm font-medium">
          <span>!</span>
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="border-t border-gray-200 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-center text-sm text-gray-400">&copy; <%= Date.current.year %> My Blog &middot; Built with Ruby on Rails</p>
      </div>
    </footer>
  </body>
</html>
